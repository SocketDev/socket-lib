--- /dev/null
+++ b/source/index.cjs
@@ -0,0 +1,26 @@
+'use strict';
+
+// compat shim: chalk@5 is ESM-only — its `exports` map offered no `require`
+// condition, so a CommonJS `require('chalk')` on Node's require(ESM) path
+// receives the module namespace ({ default, Chalk, ... }) instead of the
+// callable chalk instance the chalk@4 API exposed as `module.exports`. CJS
+// consumers (`@yarnpkg/core`, `@yarnpkg/shell`, `type-coverage`) still do
+// `const chalk = require('chalk')` then `chalk.red(...)`, so re-export the
+// default instance as `module.exports` and re-attach chalk@5's named exports.
+const namespace = require('./index.js');
+const chalk = namespace.default;
+
+module.exports = chalk;
+module.exports.default = chalk;
+module.exports.Chalk = namespace.Chalk;
+module.exports.chalkStderr = namespace.chalkStderr;
+module.exports.supportsColor = namespace.supportsColor;
+module.exports.supportsColorStderr = namespace.supportsColorStderr;
+module.exports.modifierNames = namespace.modifierNames;
+module.exports.foregroundColorNames = namespace.foregroundColorNames;
+module.exports.backgroundColorNames = namespace.backgroundColorNames;
+module.exports.colorNames = namespace.colorNames;
+module.exports.modifiers = namespace.modifiers;
+module.exports.foregroundColors = namespace.foregroundColors;
+module.exports.backgroundColors = namespace.backgroundColors;
+module.exports.colors = namespace.colors;
