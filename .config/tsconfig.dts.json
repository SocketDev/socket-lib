{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "sourceMap": false
  },
  "include": ["../src/**/*.ts", "../src/**/*.mts", "../src/**/*.cts"],
  "exclude": [
    "../.cache",
    "../dist/**/*",
    "../lib",
    "../node_modules",
    "../src/**/*.js",
    "../test"
  ]
}
