{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declarationMap": false,
    "module": "esnext",
    "noEmit": true,
    "rootDir": "../..",
    "skipLibCheck": true,
    "sourceMap": false,
    "types": ["node", "vitest"]
  },
  "include": [
    "../../src/**/*.ts",
    "../../test/**/*.ts",
    "../../test/**/*.mts"
  ],
  "exclude": [
    "../../.cache",
    "../../dist/**/*",
    "../../node_modules",
    "../../test/unit/ansi.test.mts",
    "../../test/unit/packages/normalize.test.mts"
  ]
}
